				{
					"name": "create_root_department",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const responseData = pm.response.json();",
									"const responseSchema = {",
									"    \"type\": \"object\",",
									"    \"properties\": {",
									"        \"id\": {\"type\": \"number\"},",
									"        \"name\": {\"type\": \"string\"},",
									"        \"parent\": {\"type\": [\"number\", \"null\"]},",
									"        \"created_at\": {\"type\": \"string\"}",
									"    },",
									"    \"required\": [\"id\", \"name\", \"parent\", \"created_at\"],",
									"    \"additionalProperties\": false",
									"};",
									"",
									"pm.test('Статус-код ответа должен быть 201', function () {",
									"    pm.expect(",
									"        pm.response.code,",
									"        'Убедитесь, что запрос на создание нового departmenta, содержащий корректные данные, возвращает ответ со статус-кодом 201'",
									"    ).to.equal(201);",
									"    const departmentId = _.get(responseData, 'id');",
									"    if (departmentId) {",
									"        pm.collectionVariables.set('rootDepartmentId', departmentId);",
									"    }",
									"});",
									"",
									"pm.test('Структура ответа должна соответствовать ожидаемой', function () {",
									"    pm.response.to.have.jsonSchema(responseSchema);",
									"});",
									"",
									"pm.test('Поле name должно содержать переданное значение', function () {",
									"    pm.expect(responseData.name).to.equal(pm.collectionVariables.get('departmentName'));",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"{{departmentName}}\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/departments/",
